# =============================================================================
#  FlyerPro — variáveis de ambiente
#  Copie para .env (local) ou cole no painel do Easypanel.
#
#  OBRIGATÓRIAS = você PRECISA preencher.
#  OPCIONAIS    = têm padrão no código (lib/env.ts). Pode deixar de fora.
# =============================================================================

# ----- Database (OBRIGATÓRIA) -----
# Local (docker-compose): use o valor abaixo.
# Easypanel: connection string do serviço Postgres, ex.:
#   postgresql://postgres:SUA_SENHA@db:5432/postgres
DATABASE_URL="postgresql://flyerpro:flyerpro@localhost:5432/flyerpro?schema=public"

# ----- Auth.js / NextAuth (OBRIGATÓRIAS) -----
# Gere com: npx auth secret
AUTH_SECRET="change-me"
# URL pública do app. Local: http://localhost:3000 — Easypanel: https://app.seudominio.com
AUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# ----- fal.ai (OBRIGATÓRIA) -----
FAL_KEY="your-fal-key"

# ----- Deepseek (OBRIGATÓRIA — monta o prompt on-brand) -----
DEEPSEEK_API_KEY="your-deepseek-key"

# ----- Storage (padrão: local, no volume do app) -----
# "local" = arquivos num volume do app (sem MinIO/S3). "s3" = MinIO/R2.
STORAGE_DRIVER="local"
# Pasta dos arquivos. No Easypanel, monte um VOLUME persistente nesse caminho.
UPLOADS_DIR=".uploads"

# =============================================================================
#  OPCIONAIS — têm padrão no código. Só preencha para trocar o comportamento.
# =============================================================================
# AUTH_TRUST_HOST já está tratado no código (auth.ts: trustHost=true).
# FAL_MODEL_TEXT="xai/grok-imagine-image"        # modelo text-to-image
# FAL_MODEL_EDIT="xai/grok-imagine-image/edit"   # modelo image-to-image
# DEEPSEEK_BASE_URL="https://api.deepseek.com"
# DEEPSEEK_MODEL="deepseek-chat"
#
# --- Só se STORAGE_DRIVER="s3" (MinIO / Cloudflare R2) ---
# S3_ENDPOINT="https://sistemas-minio.xblval.easypanel.host"
# S3_BUCKET="flyerpro"
# S3_ACCESS_KEY_ID="..."
# S3_SECRET_ACCESS_KEY="..."
# S3_PUBLIC_URL="https://sistemas-minio.xblval.easypanel.host/flyerpro"
# S3_FORCE_PATH_STYLE="true"
# S3_REGION="us-east-1"
