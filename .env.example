# ----- Database -----
DATABASE_URL="postgresql://flyerpro:flyerpro@localhost:5432/flyerpro?schema=public"

# ----- Auth.js (NextAuth v5) -----
# Generate with: npx auth secret
AUTH_SECRET="change-me"
# Public base URL of the app (used by Auth.js and fal webhook)
AUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# ----- fal.ai -----
FAL_KEY="your-fal-key"
# Model ids (override if fal changes the slugs)
FAL_MODEL_TEXT="xai/grok-imagine-image"
FAL_MODEL_EDIT="xai/grok-imagine-image/edit"

# ----- Deepseek (prompt builder) -----
DEEPSEEK_API_KEY="your-deepseek-key"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# ----- Object storage (S3-compatible: MinIO or Cloudflare R2) -----
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="flyerpro"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
# Set true for MinIO / path-style buckets
S3_FORCE_PATH_STYLE="true"
# Public base URL for serving stored objects (CDN or MinIO public endpoint)
S3_PUBLIC_URL="http://localhost:9000/flyerpro"
